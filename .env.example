# Kiwoom API Credentials
# Copy this file to .env and fill in your actual credentials

# Trading Mode: 'mock' for paper trading, 'real' for live trading
# Default: mock (safer default)
KIWOOM_MODE=mock

# Mock Trading API Keys (모의투자용)
KIWOOM_MOCK_APPKEY=your_mock_app_key_here
KIWOOM_MOCK_SECRETKEY=your_mock_secret_key_here

# Real Trading API Keys (실전투자용)
# ⚠️ WARNING: Use with extreme caution! Real money is at risk.
KIWOOM_REAL_APPKEY=your_real_app_key_here
KIWOOM_REAL_SECRETKEY=your_real_secret_key_here

# Legacy Keys (deprecated, for backward compatibility)
# If KIWOOM_MODE is set, these will be ignored
# KIWOOM_APPKEY=your_app_key_here
# KIWOOM_SECRETKEY=your_secret_key_here

# Optional logging configuration (used by util.logging_config.configure_logging)
# Directory where logs will be written. If not set, defaults to './logs'
# Example: KIW_LOG_DIR=/var/log/systemtrading
KIW_LOG_DIR=./logs

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Example: KIW_LOG_LEVEL=DEBUG
KIW_LOG_LEVEL=INFO

# Other optional runtime flags
# If you want to run integration tests against real API, set this to '1'
# RUN_INTEGRATION=0

# Log rotation settings for `RotatingFileHandler`
# Maximum size in bytes before rotation (e.g., 10485760 = 10MB)
KIW_LOG_ROTATION_MAX_BYTES=10485760
# Number of backup files to keep after rotation
KIW_LOG_BACKUP_COUNT=5

# Telegram Bot Configuration
# 텔레그램 봇 설정 방법:
# 1. 텔레그램에서 @BotFather와 대화
# 2. /newbot 명령으로 새 봇 생성
# 3. 봇 토큰 획득 (예: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz)
# 4. 봇과 대화 시작 (메시지 하나 보내기)
# 5. https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates 접속
# 6. "chat":{"id":123456789} 부분에서 chat_id 확인
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Trading Fee Configuration
# 거래 수수료 및 세금 설정 (단위: %, 소수점 입력 가능)
# 증권사마다 수수료율이 다르므로 본인의 증권사 수수료율을 확인하여 설정하세요

# 증권사 수수료율 (매수/매도 동일, 기본값: 0.35%)
# 예: 키움증권 모의투자 0.35%, 실전투자는 증권사별 상이 (0.015%~0.5%)
TRADING_FEE_PERCENT=0.35

# 증권거래세 (매도 시만 적용, 기본값: 0.15%)
# 2024년 기준 한국 주식 매도 시 0.15% (농어촌특별세 포함)
# 참고: 증권거래세 0.10% + 농어촌특별세 0.05% = 0.15%
TRADING_TAX_PERCENT=0.15

