# Kiwoom API Credentials
# Copy this file to .env and fill in your actual credentials

# Trading Mode: 'mock' for paper trading, 'real' for live trading
# Default: mock (safer default)
KIWOOM_MODE=mock

# Mock Trading API Keys (모의투자용)
KIWOOM_MOCK_APPKEY=your_mock_app_key_here
KIWOOM_MOCK_SECRETKEY=your_mock_secret_key_here

# Real Trading API Keys (실전투자용)
# ⚠️ WARNING: Use with extreme caution! Real money is at risk.
KIWOOM_REAL_APPKEY=your_real_app_key_here
KIWOOM_REAL_SECRETKEY=your_real_secret_key_here

# Legacy Keys (deprecated, for backward compatibility)
# If KIWOOM_MODE is set, these will be ignored
# KIWOOM_APPKEY=your_app_key_here
# KIWOOM_SECRETKEY=your_secret_key_here

# API Rate Limit Configuration
# 키움 API 호출 간격 (초 단위)
# 모의투자와 실전투자의 rate limit이 다르므로 별도 설정
# 모의투자: rate limit이 더 엄격하여 0.2초 권장
# 실전투자: 0.1초로도 안정적
KIWOOM_API_SLEEP_MOCK=0.2
KIWOOM_API_SLEEP_REAL=0.1

# Optional logging configuration (used by util.logging_config.configure_logging)
# Directory where logs will be written. If not set, defaults to './logs'
# Example: KIW_LOG_DIR=/var/log/systemtrading
KIW_LOG_DIR=./logs

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Example: KIW_LOG_LEVEL=DEBUG
KIW_LOG_LEVEL=INFO

# Other optional runtime flags
# If you want to run integration tests against real API, set this to '1'
# RUN_INTEGRATION=0

# Control whether the strategy may call Kiwoom API at runtime.
# For safety, external API calls are disabled by default. Set to '1' or 'true' to enable.
# ALLOW_KIWOOM_CALLS=0

# Log rotation settings for `RotatingFileHandler`
# Maximum size in bytes before rotation (e.g., 10485760 = 10MB)
KIW_LOG_ROTATION_MAX_BYTES=10485760
# Number of backup files to keep after rotation
KIW_LOG_BACKUP_COUNT=5

# Telegram Bot Configuration
# 텔레그램 봇 설정 방법:
# 1. 텔레그램에서 @BotFather와 대화
# 2. /newbot 명령으로 새 봇 생성
# 3. 봇 토큰 획득 (예: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz)
# 4. 봇과 대화 시작 (메시지 하나 보내기)
# 5. https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates 접속
# 6. "chat":{"id":123456789} 부분에서 chat_id 확인
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Trading Fee Configuration
# 거래 수수료 및 세금 설정 (단위: %, 소수점 입력 가능)
# 모의투자와 실전투자에 따라 자동으로 적용됩니다

# 모의투자 거래 비용
# 증권사 수수료율 (매수/매도 동일, 키움 모의투자 기본값: 0.35%)
TRADING_FEE_PERCENT_MOCK=0.35
# 증권거래세 (매도 시, 모의투자는 거래세 없음)
TRADING_TAX_PERCENT_MOCK=0.0

# 실전투자 거래 비용
# 증권사 수수료율 (매수/매도 동일, 키움 실전투자 기본값: 0.015%)
# 증권사별로 상이하므로 본인의 수수료율을 확인하여 설정하세요
TRADING_FEE_PERCENT_REAL=0.015
# 증권거래세 (매도 시만 적용, 2026년 기준: 0.20%)
# 참고: 증권거래세 0.15% + 농어촌특별세 0.05% = 0.20%
TRADING_TAX_PERCENT_REAL=0.20

# RSI 계산 방식 설정: 'cutler' 또는 'wilder' (기본: wilder)
# 예: RSI_METHOD=wilder
RSI_METHOD=wilder

# Additional compatibility and overrides
# ------------------------------------
# 우선순위: `TRADING_FEE_PERCENT_{MOCK,REAL}` 및 `TRADING_TAX_PERCENT_{MOCK,REAL}` 값을 기본으로 사용합니다.
# (예: TRADING_FEE_PERCENT_REAL=0.015 은 0.015% 를 의미)
# 호환성을 위해 소수/퍼센트 형태 모두 허용하는 폴백 변수를 제공합니다.
#  - COMMISSION_RATE: 소수(decimal) 또는 퍼센트(percent) 형태 허용
#      예: COMMISSION_RATE=0.00015  # decimal (0.015%)
#      예: COMMISSION_RATE=0.015    # percent (0.015%)
#  - TAX_RATE: 소수 또는 퍼센트 형태 허용
#      예: TAX_RATE=0.0020  # decimal (0.20%)
#      예: TAX_RATE=0.20    # percent (0.20%)

# 폴백: 수수료(소수 또는 퍼센트 입력 허용)
COMMISSION_RATE=0.00015
# 폴백: 거래세 (소수 또는 퍼센트 입력 허용, 매도 시 적용)
TAX_RATE=0.0020

# 백테스트 초기 자본금 (원)
# 설정하지 않으면 코드 기본값(10,000,000원) 사용
INITIAL_CAPITAL=10000000

# === 전략 파라미터 (Pullback in Uptrend + ATR Trailing Stop) ===
# 아래 값들이 설정되면 코드에서 하드코딩된 기본값을 덮어씁니다.

# RSI 계산 기간 (14가 표준)
RSI_PERIOD=14

# 매수 조건
RSI_BUY_THRESHOLD=30         # RSI(14) < 30 = 과매도 구간 진입
PRICE_DROP_THRESHOLD=-3.0    # 2일 연속 하락률 -3% 미만 (Pullback 확인)

# 현금 보유 비율
CASH_RESERVE_RATIO=0.2       # 20% 현금 유지

# 청산 조건
TIME_STOP_LOSS_DAYS=60       # 시간 손절: 60일 초과 시 강제 매도
ATR_TRAILING_MULTIPLE=3.0    # ATR 트레일링 스탑 (14일 ATR × 3.0)
#   stop_price = 최고가 - ATR_TRAILING_MULTIPLE * ATR
#   배수가 작을수록 타이트한 스탑, 클수록 여유 있는 스탑
# ATR_PERIOD=14              # ATR 계산 기간 (기본: 14)

# 가격 손절 (hard stop): ATR과 별도로 매입가 대비 -N% 도달 시 즉시 청산
PRICE_STOP_LOSS_PCT=-10
ENABLE_STOP_LOSS=true

# (미사용 — ATR 트레일링 스탑이 청산 담당)
# RSI_SELL_THRESHOLD=80
# PROFIT_TARGET_PERCENT=10.0

# 실시간 WebSocket 등록 가능 최대 종목 수 (키움 API 제한)
REALTIME_MAX_CODES=100
# REST 폴링으로 추가 감시할 최대 종목 수
POLLING_MAX_CODES=150
# 백테스트 월별 유니버스 크기 (미설정 시 REALTIME_MAX_CODES + POLLING_MAX_CODES 사용)
# MONTHLY_UNIVERSE_SIZE=250

# Universe ETF 정책
# - all: ETF 포함 (기존 동작)
# - exclude: ETF 전체 제외
# - only: ETF만 포함
# - auto: ETF는 whitelist만 포함 (권장)
UNIVERSE_ETF_MODE=auto

# auto 모드에서 유지할 ETF 코드 목록 (콤마 구분)
# 2026-05 백테스트 기준 권장 조합
UNIVERSE_ETF_WHITELIST_CODES=229200,381180

# auto 모드에서 유지할 ETF 종목명 목록 (선택)
# 예: UNIVERSE_ETF_WHITELIST_NAMES=KODEX 코스닥150,TIGER 미국필라델피아반도체나스닥
UNIVERSE_ETF_WHITELIST_NAMES=

# --- Recommended settings (tuning and robustness) ---
# Price fetch controls: increase initial/deep fetch loops when creating or refreshing price DB
# - PRICE_FETCH_MAX_LOOPS: number of pages to fetch for deep retrieval (default 4 => ~10 years depending on API page size)
# Set these to improve chances of getting the latest trading dates when creating or refreshing DB tables
# - PRICE_FETCH_MAX_LOOPS: number of pages to fetch for deep retrieval (default 1 => only first/latest page; increase only for full-history seeding/repair)
#
# 기본값을 1로 설정합니다. 일상적인 RSI 계산 및 일일 업데이트는 최신->과거 순 응답으로
# 첫 페이지만으로 충분하므로 기본은 1로 설정하고, 전체 시드나 복구가 필요할 때만 늘리세요.
# - PRICE_FETCH_SHALLOW_LOOPS: 제거됨. 얕은 조회는 항상 1페이지만 수행합니다.
#   전체/심층 조회는 `PRICE_FETCH_MAX_LOOPS` 하나로 관리합니다.
PRICE_FETCH_MAX_LOOPS=1

# RSI tuning and safety
# RSI_PERIOD, RSI_MIN_PERIODS, RSI_USE_CLOSED_BAR는 위 전략 파라미터 섹션 참고
RSI_MIN_PERIODS=14
RSI_USE_CLOSED_BAR=0

# If you want to debug RSI inputs, enable detailed debug logs via logger level:
# KIW_LOG_LEVEL=DEBUG
